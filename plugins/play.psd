# plugins/play.py
import yt_dlp
from pyrogram.types import Message
from plugins import queues

ydl_opts = {
    'format': 'bestaudio/best',
    'quiet': True,
    'nocheckcertificate': True,
    'ignoreerrors': True,
    'geo_bypass': True,
    'no_warnings': True,
}

async def search_youtube(query: str):
    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        try:
            info = ydl.extract_info(query, download=False)
            if 'entries' in info:
                track = info['entries'][0]
            else:
                track = info
            return {
                'title': track.get('title', 'Unknown'),
                'artist': track.get('uploader', 'Unknown'),
                'url': track.get('webpage_url'),
                'duration': track.get('duration', 0),
                'thumbnail': track.get('thumbnail', ''),
            }
        except Exception:
            return None

async def get_audio_url(url: str):
    with yt_dlp.YoutubeDL(ydl_opts) as ydl:
        info = ydl.extract_info(url, download=False)
        return info['url']

async def play(client, message: Message, bot, user, call):
    query = message.text.split(" ", 1)[1] if len(message.text.split()) > 1 else None
    if not query:
        await message.reply("Usage: `/play <song name>`")
        return
    
    msg = await message.reply(f"🔍 Searching `{query[:50]}`...")
    
    track = await search_youtube(query)
    if not track:
        await msg.edit("❌ No results found!")
        return
    
    chat_id = message.chat.id
    
    if chat_id not in queues:
        queues[chat_id] = []
    
    if not call.is_connected(chat_id):
        audio_url = await get_audio_url(track['url'])
        await call.join_group_call(chat_id, audio_url)
        from plugins import active_calls
        active_calls[chat_id] = True
        await msg.edit(f"✅ Playing: **{track['title'][:50]}**")
    else:
        queues[chat_id].append(track)
        await msg.edit(f"➕ Added to queue: **{track['title'][:50]}**\n📋 Position: `{len(queues[chat_id])}`")
